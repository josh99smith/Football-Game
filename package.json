{
  "name": "bobble-bowl",
  "version": "0.2.0",
  "description": "Bobble Bowl — bighead arcade American football (NFL Blitz-style) starring a rigged photo-scanned player, built with Three.js + TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:player": "node tools/build-player-asset.mjs"
  },
  "keywords": [
    "game",
    "football",
    "arcade",
    "canvas",
    "typescript",
    "mobile"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/three": "^0.169.0",
    "jpeg-js": "^0.4.4",
    "meshoptimizer": "^1.1.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "watlas": "^1.0.1"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "lil-gui": "^0.19.2",
    "three": "^0.169.0"
  }
}
